generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  ADMIN
  SUPERADMIN

  @@map("admin_role")
}

model admins {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username       String           @unique
  password_hash  String
  name           String?
  foto_url       String?
  foto_object_id BigInt?
  jabatan        String?          @db.VarChar(120)
  role           AdminRole        @default(ADMIN)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  foto_object    storage_objects? @relation("admins_foto_object", fields: [foto_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  push_notifications_created push_notifications[] @relation("push_notifications_created_by_admin")

  @@index([foto_object_id], map: "idx_admins_foto_object")
  @@index([role], map: "idx_admins_role")
}

model categories {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(100)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  learning_media learning_media[]
}

model institutions {
  id                 String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String
  logo_url           String?
  description        String?
  created_at         DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?        @default(now()) @db.Timestamptz(6)
  logo_object_id     BigInt?
  favicon_object_id  BigInt?
  seo_title          String?
  seo_description    String?
  seo_keywords       String?
  canonical_url      String?
  og_image_object_id BigInt?
  og_type            String?          @default("website")
  twitter_card       String?          @default("summary_large_image")
  favicon_object     storage_objects? @relation("institutions_favicon_object", fields: [favicon_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  logo_object        storage_objects? @relation("institutions_logo_object", fields: [logo_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  og_image_object    storage_objects? @relation("institutions_og_image_object", fields: [og_image_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([favicon_object_id], map: "idx_institutions_favicon_object")
  @@index([logo_object_id], map: "idx_institutions_logo_object")
  @@index([og_image_object_id], map: "idx_institutions_og_image_object")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model learning_media {
  id                  Int              @id @default(autoincrement())
  title               String           @db.VarChar(255)
  description         String?
  thumbnail_url       String
  file_url            String
  source_type         String?          @default("file") @db.VarChar(20)
  external_url        String?
  is_pinned           Boolean?         @default(false)
  pinned_at           DateTime?        @db.Timestamptz(6)
  level_id            Int
  category_id         Int
  media_type_id       Int
  visibility          String?          @default("public") @db.VarChar(20)
  download_count      Int?             @default(0)
  view_count          Int?             @default(0)
  created_at          DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?        @default(now()) @db.Timestamptz(6)
  file_object_id      BigInt?
  thumbnail_object_id BigInt?
  categories          categories       @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  file_object         storage_objects? @relation("learning_media_file_object", fields: [file_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  levels              levels           @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  media_types         media_types      @relation(fields: [media_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  media_events        media_events[]
  thumbnail_object    storage_objects? @relation("learning_media_thumbnail_object", fields: [thumbnail_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([category_id], map: "idx_learning_media_category")
  @@index([file_object_id], map: "idx_learning_media_file_object")
  @@index([level_id], map: "idx_learning_media_level")
  @@index([media_type_id], map: "idx_learning_media_media_type")
  @@index([thumbnail_object_id], map: "idx_learning_media_thumbnail_object")
  @@index([visibility], map: "idx_learning_media_visibility")
}

model levels {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(50)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  learning_media learning_media[]
}

model media_types {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(50)
  icon           String?          @db.VarChar(50)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  learning_media learning_media[]
}

model media_events {
  id         BigInt         @id @default(autoincrement())
  media_id   Int
  event_type String         @db.VarChar(20)
  source     String?        @db.VarChar(30)
  ip_hash    String?        @db.VarChar(128)
  user_agent String?
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  media      learning_media @relation(fields: [media_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at], map: "idx_media_events_created_at")
  @@index([event_type], map: "idx_media_events_event_type")
  @@index([media_id], map: "idx_media_events_media_id")
}

model push_notifications {
  id                  BigInt    @id @default(autoincrement())
  title               String    @db.VarChar(160)
  body                String    @db.VarChar(600)
  target_url          String?
  payload             Json?
  success_count       Int       @default(0)
  failure_count       Int       @default(0)
  sent_at             DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  created_by_admin_id String?   @db.Uuid
  created_by_admin    admins?   @relation("push_notifications_created_by_admin", fields: [created_by_admin_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([created_at], map: "idx_push_notifications_created_at")
  @@index([created_by_admin_id], map: "idx_push_notifications_created_by_admin")
  @@index([sent_at], map: "idx_push_notifications_sent_at")
}

model push_subscriptions {
  id         BigInt   @id @default(autoincrement())
  endpoint   String   @unique
  p256dh     String
  auth       String
  user_agent String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([is_active], map: "idx_push_subscriptions_is_active")
  @@index([updated_at], map: "idx_push_subscriptions_updated_at")
}

model social_links {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  icon       String
  link       String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  name       String    @default("Social Media")
}

model storage_objects {
  id                              BigInt           @id @default(autoincrement())
  provider                        String           @default("r2")
  bucket                          String
  object_key                      String
  mime_type                       String?
  size_bytes                      BigInt?
  etag                            String?
  checksum_sha256                 String?
  is_public                       Boolean          @default(true)
  created_at                      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime         @default(now()) @db.Timestamptz(6)
  admins_foto_object              admins[]         @relation("admins_foto_object")
  institutions_favicon_object     institutions[]   @relation("institutions_favicon_object")
  institutions_logo_object        institutions[]   @relation("institutions_logo_object")
  institutions_og_image_object    institutions[]   @relation("institutions_og_image_object")
  learning_media_file_object      learning_media[] @relation("learning_media_file_object")
  learning_media_thumbnail_object learning_media[] @relation("learning_media_thumbnail_object")

  @@unique([provider, bucket, object_key], map: "uq_storage_object")
  @@index([bucket, object_key], map: "idx_storage_objects_bucket_key")
}
